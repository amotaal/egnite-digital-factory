    "instructions": [
      {
        "id": "s1",
        "icon": "🥣",
        "text": {
          "en": "Melt butter and allow to cool slightly.",
          "ar": "أذب الزبدة واتركها تبرد قليلاً."
        }
      },
      {
        "id": "s2",
        "icon": "🍚",
        "text": {
          "en": "Whisk eggs, sugar, and Coconut Essence until combined.",
          "ar": "اخفق البيض والسكر وجوهر جوز الهند حتى يتجانس."
        }
      },
      {
        "id": "s3",
        "icon": "🌾",
        "text": {
          "en": "Fold in flour and desiccated coconut.",
          "ar": "أضف الدقيق وجوز الهند المجفف برفق."
        }
      },
      {
        "id": "s4",
        "icon": "🧈",
        "text": {
          "en": "Stir in melted butter. Chill batter 30 minutes.",
          "ar": "أضف الزبدة المذابة وبرّد العجين 30 دقيقة."
        }
      },
      {
        "id": "s5",
        "icon": "🫙",
        "text": {
          "en": "Fill greased madeleine mould and bake 180°C for 12 min.",
          "ar": "املأ قالب المادلين المدهون واخبز 180°م لمدة 12 دقيقة."
        }
      }
