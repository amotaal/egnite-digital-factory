      },
      {
        "id": "i5",
        "icon": "🧪",
        "label": {
          "en": "Vanilla Essence",
          "ar": "جوهر الفانيليا"
        },
        "amount": "½ tsp (2.5g)"
      },
      {
        "id": "i6",
        "icon": "🍓",
        "label": {
          "en": "Strawberry Essence",
          "ar": "جوهر الفراولة"
        },
        "amount": "½ tsp (2.5g)"
      },
      {
        "id": "i7",
        "icon": "🥛",
        "label": {
          "en": "Heavy Cream",
          "ar": "كريم للخفق"
        },
        "amount": "300ml"
      }
    ],
    "instructions": [
      {
        "id": "s1",
        "icon": "🥣",
        "text": {
          "en": "Whisk eggs and sugar until pale and thick, about 5 minutes.",
          "ar": "اخفق البيض والسكر حتى يصبح فاتح اللون وكثيف لمدة 5 دقائق."
        }
      },
      {
        "id": "s2",
        "icon": "🌾",
        "text": {
          "en": "Fold in sifted flour gently, then add melted butter.",
          "ar": "أضف الدقيق المنخول برفق ثم أضف الزبدة المذابة."
        }
      },
      {
        "id": "s3",
        "icon": "🧪",
        "text": {
          "en": "Add Vanilla Essence and mix until just combined.",
          "ar": "أضف جوهر الفانيليا وامزج حتى يتجانس."
        }
      },
      {
        "id": "s4",
        "icon": "🫙",
        "text": {
          "en": "Pour into greased cups and bake at 180°C for 18–20 min.",
          "ar": "صب في كوبايات مدهونة واخبز على 180°م لمدة 18-20 دقيقة."
        }
      },
      {
        "id": "s5",
        "icon": "🍓",
        "text": {
          "en": "Make syrup: heat strawberries with sugar and Strawberry Essence.",
          "ar": "اصنع الشراب: سخّن الفراولة مع السكر وجوهر الفراولة."
        }
      },
      {
        "id": "s6",
        "icon": "🍦",
        "text": {
          "en": "Soak cooled cakes with syrup, top with whipped cream.",
          "ar": "بلل الكيك المبرد بالشراب وأضف الكريم المخفوق فوقه."
        }
      }
    ],
