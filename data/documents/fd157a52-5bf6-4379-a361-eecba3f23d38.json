    "instructions": [
      {
        "id": "s1",
        "icon": "🥣",
        "text": {
          "en": "Cream butter and sugar. Beat in egg.",
          "ar": "اخفق الزبدة والسكر. أضف البيض."
        }
      },
      {
        "id": "s2",
        "icon": "🌾",
        "text": {
          "en": "Divide dough in half. Mix Bavarian Cream into one half.",
          "ar": "قسّم العجين لنصفين. أضف البافاريان كريم لأحد النصفين."
        }
      },
      {
        "id": "s3",
        "icon": "🟫",
        "text": {
          "en": "Add Lotus Essence and Brown Color to the second half.",
          "ar": "أضف جوهر اللوتس واللون البني للنصف الثاني."
        }
      },
      {
        "id": "s4",
        "icon": "🌀",
        "text": {
          "en": "Roll both doughs, stack, roll up into a log, chill 1 hour.",
          "ar": "افرد العجينتين، ضعهما فوق بعض، لفّهما لفّة واحدة وبرّد ساعة."
        }
      },
      {
        "id": "s5",
        "icon": "🔪",
        "text": {
          "en": "Slice and bake at 175°C for 12–14 minutes.",
          "ar": "شرّح واخبز على 175°م لمدة 12-14 دقيقة."
        }
      }
    ],
