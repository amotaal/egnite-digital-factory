            "icon": "🥣",
            "text": {
              "en": "Beat butter until pale.",
              "ar": "اخفق الزبدة حتى تصبح شاحبة."
            }
          },
          {
            "id": "es4",
            "icon": "❄️",
            "text": {
              "en": "Sift in icing sugar and essence, whip to stiff peaks.",
              "ar": "أضف السكر الناعم والجوهر واخفق حتى التماسك."
            }
          }
